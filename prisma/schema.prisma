generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Pillar {
  VASCULAR
  NERVOUS
  BLOOD
  KIDNEY
}

enum TimeBlock {
  MORNING
  MIDDAY
  AFTERNOON
  EVENING
}

enum BPPeriod {
  AM
  PM
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  name              String?
  image             String?
  wakeUpTime        String    @default("06:00")
  timezone          String    @default("America/Chicago")
  protocolStartDate DateTime?
  pushSubscription  Json?
  pushEnabled       Boolean   @default(false)
  onboarded         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  completions ChecklistCompletion[]
  bpEntries   BPEntry[]
  streak      Streak?
  milestones  MilestoneAchievement[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ChecklistItem {
  slug        String    @id
  title       String
  description String?
  pillar      Pillar?
  timeBlock   TimeBlock
  phase       Int       @default(1)
  sortOrder   Int

  completions ChecklistCompletion[]
}

model ChecklistCompletion {
  id        String   @id @default(cuid())
  userId    String
  itemSlug  String
  date      String
  createdAt DateTime @default(now())

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ChecklistItem @relation(fields: [itemSlug], references: [slug], onDelete: Cascade)

  @@unique([userId, itemSlug, date])
  @@index([userId, date])
}

model BPEntry {
  id        String   @id @default(cuid())
  userId    String
  systolic  Int
  diastolic Int
  pulse     Int?
  period    BPPeriod
  date      String
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, period])
  @@index([userId, date])
}

model Streak {
  id             String  @id @default(cuid())
  userId         String  @unique
  currentStreak  Int     @default(0)
  longestStreak  Int     @default(0)
  lastActiveDate String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MilestoneAchievement {
  id         String   @id @default(cuid())
  userId     String
  milestone  String
  achievedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestone])
}
